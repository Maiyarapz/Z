-- COMBAT LOOP
-- ========================
local lastAttack = 0
RunService.Heartbeat:Connect(function()
    local root = GetRootPart()
    if not root then return end

    -- Auto Farm Mobs / Kill Aura
    if Toggles.AutoFarmMobs or Toggles.KillAura then
        local mob = GetNearestMob(60)
        if mob then
            local mobRoot = mob:FindFirstChild("HumanoidRootPart")
            if mobRoot then
                root.CFrame = CFrame.new(mobRoot.Position + Vector3.new(0, 0, 3.5))
                if tick() - lastAttack > 0.15 then
                    lastAttack = tick()
                    if RequestHit then RequestHit:FireServer(mob, mobRoot.Position) end
                    if CombatRemote then CombatRemote:FireServer("Attack", mob) end
                end
            end
        end
    end

    if Toggles.AutoHaki and HakiRemote then HakiRemote:FireServer("Activate") end
    if Toggles.AutoObsHaki and ObsHakiRemote then ObsHakiRemote:FireServer("Activate") end
    
    if Toggles.AutoStats and tick() % 1 < 0.05 then
        if AllocateStat then 
            AllocateStat:FireServer("Strength", 1) 
            AllocateStat:FireServer("Defense", 1) 
            AllocateStat:FireServer("Speed", 1) 
        end
    end
end)

