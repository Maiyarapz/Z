-- GUI Helpers
local function CreateToggle(parent, label, toggleKey, callback)
    local Row = Instance.new("TextButton") -- ใช้ TextButton เพื่อให้กดง่าย
    Row.Size = UDim2.new(1, 0, 0, 42)
    Row.BackgroundColor3 = Color3.fromRGB(28, 28, 44)
    Row.Text = ""
    Row.Parent = parent
    Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 8)

    local Lbl = Instance.new("TextLabel")
    Lbl.Size = UDim2.new(1, -60, 1, 0)
    Lbl.Position = UDim2.new(0, 10, 0, 0)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = label
    Lbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    Lbl.TextSize = 13
    Lbl.Font = Enum.Font.Gotham
    Lbl.TextXAlignment = Enum.TextXAlignment.Left
    Lbl.Parent = Row

    local Dot = Instance.new("Frame")
    Dot.Size = UDim2.new(0, 18, 0, 18)
    Dot.Position = UDim2.new(1, -30, 0.5, -9)
    Dot.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    Dot.Parent = Row
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

    Row.MouseButton1Click:Connect(function()
        Toggles[toggleKey] = not Toggles[toggleKey]
        Dot.BackgroundColor3 = Toggles[toggleKey] and Color3.fromRGB(60, 200, 90) or Color3.fromRGB(50, 50, 70)
        if callback then callback(Toggles[toggleKey]) end
    end)
end

local function CreateButton(parent, label, color, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 0, 36)
    Btn.BackgroundColor3 = color or Color3.fromRGB(50, 100, 200)
    Btn.Text = label
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Font = Enum.Font.GothamBold
    Btn.Parent = parent
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
    Btn.MouseButton1Click:Connect(callback)
end

